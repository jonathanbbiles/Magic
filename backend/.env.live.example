APCA_API_KEY_ID=YOUR_ALPACA_KEY_ID
APCA_API_SECRET_KEY=YOUR_ALPACA_SECRET_KEY
# Alternate key envs also supported:
# ALPACA_KEY_ID, ALPACA_API_KEY_ID, ALPACA_API_KEY
# Alternate secret envs also supported:
# ALPACA_SECRET_KEY, ALPACA_API_SECRET_KEY
# Use either ALPACA_API_BASE or TRADE_BASE for live trading.
TRADE_BASE=https://api.alpaca.markets
# ALPACA_API_BASE=https://api.alpaca.markets
DATA_BASE=https://data.alpaca.markets
TRADING_ENABLED=true
MAX_CONCURRENT_POSITIONS=0
ENTRY_SCAN_INTERVAL_MS=12000
API_TOKEN=<your long random token>
# NOTE: Updating this file in git does NOT update deployed Render env vars automatically.
# After merge, you must manually copy these values into the real Render service environment.
# Optional: allow LAN/device origins for Expo.
# Persist recorder/training artifacts on a mounted volume in production.
DATASET_DIR=/mnt/data
CORS_ALLOW_LAN=true
# === Exits & Risk ===
SELL_REPRICE_ENABLED=1
EXIT_CANCELS_ENABLED=1
EXIT_MARKET_EXITS_ENABLED=1
ALLOW_TAKER_BEFORE_TARGET=1
# Faster rotation / less stale orders:
SELL_ORDER_TTL_MS=15000
MIN_REPRICE_INTERVAL_MS=15000
REPRICE_IF_AWAY_BPS=6
MAX_HOLD_SECONDS=300
# Safety: default OFF, but available:
EXIT_CANCELS_FORCE_ALL=0
EXIT_RECONCILE_MISS_THRESHOLD=5
EXIT_RECONCILE_MIN_CONFIRM_MS=60000
POST_FILL_POSITION_SETTLE_MS=15000
POST_FILL_POSITION_POLL_MS=750
POST_FILL_EXIT_ATTACH_ATTEMPTS=20

# Alpaca market-data throttling (helps avoid HTTP 429 on bars)
BARS_MAX_CONCURRENT=1
BARS_MIN_TIME_MS=300
# Capped in code at 20; keep this intentionally low in live to reduce market-data pressure.
ENTRY_PREFETCH_CHUNK_SIZE=3
ENTRY_PREFETCH_ORDERBOOKS=false
ALPACA_MD_MAX_CONCURRENCY=1
ALPACA_MD_MIN_DELAY_MS=200
ALPACA_MD_MAX_RETRIES=6
ALPACA_MD_BASE_BACKOFF_MS=500
ALPACA_BARS_USE_TIME_RANGE=true
BARS_PREFETCH_INTERVAL_MS=120000
ALLOW_PER_SYMBOL_BARS_FALLBACK=true
PREDICTOR_WARMUP_FALLBACK_BUDGET_PER_SCAN=2
PREDICTOR_WARMUP_BLOCK_TRADES=false
PREDICTOR_WARMUP_PREFETCH_CONCURRENCY=1
PREDICTOR_MIN_BARS_1M=30
PREDICTOR_MIN_BARS_5M=30
PREDICTOR_MIN_BARS_15M=20

# --- Entry tuning ---
# Predictor probability thresholds by tier.
MIN_PROB_TO_ENTER=0.35
MIN_PROB_TO_ENTER_TIER1=0.35
MIN_PROB_TO_ENTER_TIER2=0.40
# Predictor gating:
# TP-aligned move target in bps (this is what you actually take profit on; e.g. 60-90)
ENTRY_TAKE_PROFIT_BPS=70

# Stretch confidence move target in bps (this is what you "want to see" for confidence; e.g. 100-150)
ENTRY_STRETCH_MOVE_BPS=100

# Entry gate uses TP probability threshold
MIN_PROB_TO_ENTER_TP=0.53

# Optional second confidence filter; 0 disables it
MIN_PROB_TO_ENTER_STRETCH=0

# Stop-loss (bps). If unset, backend scales from TARGET_PROFIT_BPS; override here if desired.
STOP_LOSS_BPS=50

# Entry buffer (bps) added into spread gate only (small sanity margin)
ENTRY_BUFFER_BPS=10

# EV guard (corrected to maker-first fees via feeBpsRoundTrip()).
EV_GUARD_ENABLED=true
EV_MIN_BPS=5
EV_BUFFER_BPS=0

# Fees (bps). feeBpsRoundTrip() = maker + (taker_on_touch ? taker : maker)
FEE_BPS_MAKER=10
FEE_BPS_TAKER=20

# Optional slippage (bps) added to EV cost model
SLIPPAGE_BPS=0

STOPS_ENABLED=1
STOPLOSS_ENABLED=1
STOPLOSS_MODE=atr

# Optional safety hard timeout: force-close positions older than 1 hour.
# FORCE_EXIT_SECONDS=3600
# FORCE_EXIT_ALLOW_LOSS=1

# --- Regime / confidence / failed-trade controls ---
REGIME_MAX_SPREAD_BPS=40
REGIME_MIN_VOL_BPS=15
REGIME_MIN_VOL_BPS_TIER1=4
REGIME_MIN_VOL_BPS_TIER2=8
REGIME_MAX_VOL_BPS=250
REGIME_REQUIRE_MOMENTUM=true
REGIME_BLOCK_WEAK_LIQUIDITY=true
REGIME_ALLOW_UNKNOWN_VOL=false
VOL_COMPRESSION_MIN_RATIO=0.60
VOL_COMPRESSION_MIN_LONG_VOL_BPS=8
VOL_COMPRESSION_MIN_LONG_VOL_BPS_TIER1=2
VOL_COMPRESSION_MIN_LONG_VOL_BPS_TIER2=4
ORDERBOOK_ABSORPTION_ENABLED=false
ORDERBOOK_MIN_DEPTH_USD=175
ORDERBOOK_MIN_LEVELS_PER_SIDE=2
ORDERBOOK_SPARSE_CONFIRM_RETRY=true
ORDERBOOK_SPARSE_CONFIRM_RETRY_MS=150
ORDERBOOK_SPARSE_FALLBACK_ENABLED=true
ORDERBOOK_SPARSE_FALLBACK_SYMBOLS=BTC/USD,ETH/USD
ORDERBOOK_SPARSE_MAX_SPREAD_BPS=12
ORDERBOOK_SPARSE_REQUIRE_STRONGER_EDGE_BPS=240
ORDERBOOK_SPARSE_REQUIRE_QUOTE_FRESH_MS=5000
ORDERBOOK_SPARSE_STALE_QUOTE_TOLERANCE_MS=15000
ORDERBOOK_SPARSE_MIN_PROBABILITY=0.60
ORDERBOOK_SPARSE_CONFIDENCE_CAP_MULT=0.50
ORDERBOOK_SPARSE_RETRY_ONCE=true
ORDERBOOK_SPARSE_CONFIRM_MAX_PER_SCAN=1
EXECUTION_TIER1_SYMBOLS=BTC/USD,ETH/USD
EXECUTION_TIER2_SYMBOLS=AVAX/USD,LINK/USD
EXECUTION_TIER3_DEFAULT=false
ENTRY_UNIVERSE_MODE=configured
ALLOW_DYNAMIC_UNIVERSE_IN_PRODUCTION=false
ENTRY_SYMBOLS_PRIMARY=BTC/USD,ETH/USD,AVAX/USD,LINK/USD
ENTRY_SYMBOLS_SECONDARY=
ENTRY_SYMBOLS_INCLUDE_SECONDARY=false
SUPPORTED_CRYPTO_PAIRS_REFRESH_MS=3600000
MARKETDATA_DEDUPE_ENABLED=true
MARKETDATA_QUOTE_TTL_MS=3000
MARKETDATA_ORDERBOOK_TTL_MS=2000
MARKETDATA_BARS_TTL_MS=10000
MARKETDATA_RATE_LIMIT_COOLDOWN_MS=15000

MIN_NET_EDGE_BPS=5
ENTRY_PROFIT_BUFFER_BPS=5
# Optional legacy override. Leave unset to use derived economics from TP/cost model.
# REQUIRED_EDGE_BPS=200
TARGET_PROFIT_BPS=140
FEE_BPS_ROUND_TRIP=20
ENTRY_SLIPPAGE_BUFFER_BPS=10
EXIT_SLIPPAGE_BUFFER_BPS=10

MOMENTUM_MIN_STRENGTH=0.15
REVERSION_MIN_RECOVERY_STRENGTH=0.10

FAILED_TRADE_MAX_AGE_SEC=90
FAILED_TRADE_MIN_PROGRESS_PCT=0.10
FAILED_TRADE_EXIT_ON_MOMENTUM_LOSS=true

CONFIDENCE_SIZING_ENABLED=true
CONFIDENCE_MIN_MULTIPLIER=0.35
CONFIDENCE_MAX_MULTIPLIER=1.00
KELLY_ENABLED=false
KELLY_FRACTION_MULT=0.25
KELLY_MAX_FRACTION=0.05
KELLY_MIN_PROB_EDGE=0.02
KELLY_MIN_REWARD_RISK=1.10
KELLY_USE_CONFIDENCE_MULT=true
KELLY_SHADOW_MODE=true
CONFIDENCE_PROB_WEIGHT=0.35
CONFIDENCE_SPREAD_WEIGHT=0.20
CONFIDENCE_LIQUIDITY_WEIGHT=0.20
CONFIDENCE_MOMENTUM_WEIGHT=0.15
CONFIDENCE_REGIME_WEIGHT=0.10

STANDDOWN_AFTER_LOSSES=3
STANDDOWN_WINDOW_MIN=30
STANDDOWN_DURATION_MIN=20

# Engine v2 feature flags (safe rollout)
ENGINE_V2_ENABLED=false
ENTRY_INTENTS_ENABLED=false
REGIME_ENGINE_V2_ENABLED=false
ADAPTIVE_ROUTING_ENABLED=false
EXIT_MANAGER_V2_ENABLED=false
SESSION_GOVERNOR_ENABLED=false
EXECUTION_ANALYTICS_V2_ENABLED=false
DASHBOARD_V2_META_ENABLED=false
SHADOW_INTENTS_ENABLED=false

# Engine v2 knobs
ENTRY_CONFIRMATION_SAMPLES=3
ENTRY_CONFIRMATION_WINDOW_MS=600
ENTRY_CONFIRMATION_MAX_SPREAD_DRIFT_BPS=4
ENTRY_EXPECTED_NET_EDGE_FLOOR_BPS=5
ROUTING_IOC_URGENCY_SCORE=0.72
ROUTING_PASSIVE_MAX_SPREAD_BPS=12
SESSION_GOVERNOR_FAIL_COOLDOWN_MS=60000
