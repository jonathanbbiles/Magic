ENTRY_CONFIRMATION_MAX_SPREAD_DRIFT_BPS=4
ENTRY_EXPECTED_NET_EDGE_FLOOR_BPS=5
ROUTING_IOC_URGENCY_SCORE=0.72
ROUTING_PASSIVE_MAX_SPREAD_BPS=12
SESSION_GOVERNOR_FAIL_COOLDOWN_MS=60000

# === Corrected entry economics (backend/modules/entryEconomics.js) ===
# These knobs replace the OLS-CDF "fillProbability" proxy used in the EV gate
# with a forward-looking GBM barrier-hitting probability, and add a hard
# cost-floor that refuses trades whose static GTC target cannot pay for
# spread + slippage + fees + min-net-edge. See `npm run reconcile` and
# `node scripts/simulate_strategy.js` for the diagnostic story.
CORRECTED_FILL_PROB_ENABLED=true   # use GBM barrier hitting prob instead of slope-CDF proxy
ENFORCE_GROSS_TARGET_FLOOR=true    # refuse trades whose target cannot beat costs
HONEST_EV_GATE_ENABLED=true        # default ON: charge non-fill branch a stuck-loss penalty (set false to revert)
STUCK_LOSS_ASSUMED_BPS=250         # MTM loss assumed for unfilled positions; raised from 100 to match live ~270 bps observed drawdowns
BARRIER_HORIZON_BARS=              # default = BREAKEVEN_TIMEOUT_MS / 60000

# === Top-detection entry gates (defaults ON after live diagnostics) ===
HTF_MIN_SLOPE_BPS_PER_BAR=1         # minimum HTF slope (5m default) required to enter; 0 = legacy "non-negative only"
MIN_VOLUME_RATIO_TO_ENTER=1.0       # refuse entries when recent-window volume < ratio × lookback mean; 0 = off
MAX_BTC_LEAD_LAG_DROP_BPS=-10       # refuse non-BTC entries when BTC's last-5-bar return is more negative than this; 0 = off

# === Portfolio-level entry gate ===
# Refuses ALL new entries when aggregate unrealized P&L (sum / cost-basis, %)
# is below threshold. The missing macro filter — caught the 11-position
# cluster that opened during a broad crypto sell-off because each per-symbol
# gate had no portfolio context. Skip reason: portfolio_drawdown_below_min.
MIN_PORTFOLIO_UNREALIZED_PCT_TO_ENTER=-0.5  # tightened from -2.0 to half-day's P&L at +1%/day target; 0 = off

# === Recent-high proximity entry gate (default ON) ===
# Refuses entries where the bid is within REJECT_NEAR_HIGH_BPS of the highest
# close in the last REJECT_NEAR_HIGH_LOOKBACK_BARS minutes. The surgical fix
# for the "we bought when the market was too high and got stuck" failure mode.
# Uses already-fetched closes — no extra Alpaca call. Skip reason: near_recent_high.
# 2026-05-17: lookback default flipped 60 → 30. The 60-bar window was rejecting
# ~50% of MR candidates by pinning the gate to stale 45-min-old peaks; the
# 30-bar window keeps the "don't buy the very top" intent without blocking
# fresh-capitulation entries that have already left the recent peak. Stale
# Render env values carrying the prior 60 are forced back to 30 at bootstrap;
# set REJECT_NEAR_HIGH_LOOKBACK_BARS_ALLOW_60=true to opt back into 60 with
# a verified emergency reason.
REJECT_NEAR_HIGH_ENABLED=true
REJECT_NEAR_HIGH_BPS=30                     # refuse within this bps of the recent high
REJECT_NEAR_HIGH_LOOKBACK_BARS=30           # = last half-hour at 1m bars

# === Signal selector + backtest veto (the self-correcting brain) ===
# Auto-picks 'ols' or 'multi_factor' based on the most recent backtest, and
# vetoes ALL entries when no signal has cleared the activation threshold.
# The selector lives in backend/modules/signalSelector.js; decision is
# surfaced at meta.signalSelector on /dashboard.
#   SIGNAL_VERSION  empty=auto (default); 'ols' or 'multi_factor' to operator-pin.
#   SIGNAL_SELECTOR_MIN_BPS                threshold (bps net per entry over
#                                          last 30-day backtest) for a signal
#                                          to be considered validated. Default +3.
#   SIGNAL_SELECTOR_VETO_ENABLED           when true (default), refuses entries
#                                          when no signal validated. Set false
#                                          for legacy "trade anyway" behaviour.
#   SIGNAL_SELECTOR_MIN_BACKTEST_ENTRIES   sample-size floor for backtest validity.
SIGNAL_VERSION=                              # blank = auto-select; 'ols' | 'multi_factor' | 'mean_reversion' to pin
SIGNAL_SELECTOR_MIN_BPS=3                    # +3 bps net per entry threshold
SIGNAL_SELECTOR_VETO_ENABLED=true            # default ON — stops capital bleed when no edge
SIGNAL_SELECTOR_MIN_BACKTEST_ENTRIES=30      # min trades in backtest to count as validated

# === Mean-reversion-at-extremes signal (the "tiny wins" candidate) ===
# Enters on volume-confirmed 1%+ capitulation drops where BTC is NOT
# correlatedly crashing and RSI confirms exhaustion. Targets half the drop
# magnitude (statistically high-probability mean reversion). Tight stop +
# fast exit because the strategy thesis is "reversion happens fast or it
# doesn't."
MR_TARGET_NET_PROFIT_BPS_FLOOR=5         # tiny minimum net target (matches "tiny wins" goal)
MR_SIGNAL_TARGET_MAX_NET_BPS=120         # cap on per-trade net target
MR_STOP_LOSS_BPS=60                      # tier-1/2 stop cap, mean reversion is fast or it fails
MR_STOP_LOSS_BPS_TIER3=100               # tier-3 (long-tail alt) stop cap; wider for ~70-90 bps spreads
# Per-timeframe MR stop caps (2026-05-17 Stage 3). Defaults match the 1m values
# so wiring is zero-behavior-change until you set one. Use these to widen the
# 5m / 15m stops independently from the 1m live signal — the only knob path
# that could turn MR-5m / MR-15m positive without lowering MR_DROP_TRIGGER_BPS
# (which the in-code A/B forbids). Live MR-5m at the 60-bps cap loses on 41%
# of fills at avg -32.6 bps net; widening the 5m cap to 80-100 is the
# experiment Stage 3 unlocks. Backtest first via:
#   /debug/backtest?days=90&refresh=true&strategy=mean_reversion&mrTimeframe=5m&mrStopLossBps5m=100
MR_STOP_LOSS_BPS_5M=40                   # tier-1/2 cap when mrTimeframe=5m (2026-06-05: 60→40, stop below TP)
MR_STOP_LOSS_BPS_5M_TIER3=70             # tier-3 cap when mrTimeframe=5m (2026-06-05: 100→70)
MR_STOP_LOSS_BPS_15M=60                  # tier-1/2 cap when mrTimeframe=15m
MR_STOP_LOSS_BPS_15M_TIER3=100           # tier-3 cap when mrTimeframe=15m
# Stage 3 sweep diagnostic. Runs at restart, results surface at
# meta.mrStopLossSweep on the dashboard. Set ENABLED=false to skip the
# extra startup work; tweak CAPS (comma-separated, ≤6 entries) to test
# different stop-loss bracketing.
MR_STOP_LOSS_SWEEP_ENABLED=true
MR_STOP_LOSS_SWEEP_CAPS=80,120,160,200
MR_MAX_HOLD_MS=2700000                   # 45 min hard exit
MR_BREAKEVEN_TIMEOUT_MS=1800000          # 30 min staircase decay window

# --- MR signal sub-gate knobs (2026-05-17 Stage 2 plumbing) ---
# Defaults mirror the in-code DEFAULT_CONFIG so wiring is zero-behavior-change
# until a Render env override is set. Tune ONE knob at a time and validate
# against /debug/backtest?days=90&refresh=true before flipping live.
# DO NOT lower MR_DROP_TRIGGER_BPS below 100: the in-code A/B (see
# modules/meanReversionSignal.js:44-50) showed an 80-bps trigger flipped
# expectancy from +14.91 to -24 bps net.
MR_DROP_TRIGGER_BPS=100                  # min cumulative 3-bar drop bps; KEEP at 100
MR_VOL_CONFIRM_MULTIPLIER=1.5            # 3-bar vol must exceed Nx baseline; loosen toward 1.2-1.3 cautiously
MR_MAX_BTC_DROP_BPS=50                   # reject if BTC dropped > Nbps in last 5 bars; widen to 75 to admit mild-cascade MR
MR_RSI_OVERSOLD=30                       # RSI(14) must be below this; loosen to 35-40 for more candidates
MR_DEEP_DROP_GUARD_BPS=300               # reject if 15-bar return < -Nbps (don't catch falling knives)

# === Phase 1: max-out Alpaca ===
# Master kill switch — false reverts ALL Phase 1 layers in one env flip.
PHASE1_ENABLED=true
# Multi-timeframe MR (5m / 15m). Adds backtest variants; selector picks best.
MR_TIMEFRAME_5M_ENABLED=true
MR_TIMEFRAME_15M_ENABLED=true
# Concurrent-position soft cap. Prevents fragmenting cash across too many
# positions for the sizing math to fund. Disable with the _ENABLED flag.
CONCURRENT_POSITIONS_SOFT_CAP_ENABLED=true
MAX_CONCURRENT_POSITIONS_SOFT_CAP=8
# Range mean-reversion: smaller drops within established ranges; high frequency.
RANGE_MR_ENABLED=true
RANGE_MR_DROP_TRIGGER_BPS=50
RANGE_MR_RANGE_LOOKBACK_BARS=60
RANGE_MR_MAX_RANGE_PCT=0.015             # 1.5% of mid
RANGE_MR_TARGET_NET_BPS_FLOOR=5
RANGE_MR_SIGNAL_TARGET_MAX_NET_BPS=60
RANGE_MR_STOP_LOSS_BPS=40
RANGE_MR_MAX_HOLD_MS=1800000             # 30 min
RANGE_MR_BREAKEVEN_TIMEOUT_MS=900000     # 15 min
# Adaptive sizing: confidence-based multiplier on PORTFOLIO_SIZING_PCT.
ADAPTIVE_SIZING_ENABLED=true
MAX_SIZING_FRACTION_OF_TARGET=1.5        # cap upper bound at 1.5× base sizing

# === Loss-bleed fixes (after live scorecard showed 0/4 win rate) ===
# Fix 1: rest the buy below the ask. 'mid' = (ask+bid)/2 saves ~half the
# spread; 'bid_plus_tick' rests one tick above bid (most passive); 'ask'
# restores the legacy cross-the-spread behaviour. ENTRY_FILL_TIMEOUT_MS
# cancels the pending buy if it hasn't filled in time (0 disables — passive
# rests until the staircase or stop catches the eventual fill).
ENTRY_LIMIT_PRICE_MODE=mid                # ask | mid | bid_plus_tick
ENTRY_FILL_TIMEOUT_MS=30000               # cancel unfilled buys after N ms; 0 = disable
# Fix 2: refuse trades whose own model says the move won't be big enough to
# fill the TP (projectedBps < grossTarget + entry/exit slippage).
ENFORCE_PROJECTED_COVERS_GROSS=true       # skip reason: projected_below_gross_target
# Fix 3: hard time-based market exit. After MAX_HOLD_MS the resting GTC sell
# is cancelled and a market IOC sell closes the position. Closes positions
# that never tripped the stop and never wicked to TP/break-even. 0 disables.
MAX_HOLD_MS=5400000                       # 90 min (tightened from 6 h: scalps that don't resolve fast must recycle capital)
# Fix 4: tighter stop cap (35 bps default) and floor (15 bps). Vol-scaled stop
# still picks a value in [floor, cap] from realised entry-time volatility.
STOP_LOSS_BPS=35
STOP_LOSS_BPS_FLOOR=15
# Fix 5: tighter quote-staleness cutoff for entries (was 60 s — crypto moves
# 20–30 bps in 30 s, which is most of the strategy's TP). Grace window absorbs
# provider timestamp lag without blanket-rejecting fresh quotes.
ENTRY_QUOTE_MAX_AGE_MS=15000
ENTRY_QUOTE_STALE_GRACE_MS=15000
# Per-symbol stale-quote pruner. After STALE_QUOTE_PRUNE_LOOKBACK observed
# fetches whose fresh-fraction drops below STALE_QUOTE_PRUNE_MIN_FRESH_RATIO,
# the symbol is dropped from the rest of the entry gate (and counted as
# `pruned_stale_quotes`). Re-admits after STALE_QUOTE_PRUNE_PROBATION_FRESH
# consecutive fresh observations.
STALE_QUOTE_PRUNE_ENABLED=true
STALE_QUOTE_PRUNE_LOOKBACK=8
STALE_QUOTE_PRUNE_MIN_FRESH_RATIO=0.4
STALE_QUOTE_PRUNE_PROBATION_FRESH=2
# Faster staircase decay (was 4 h) so losing positions either close at
# break-even or trip the stop sooner.
BREAKEVEN_TIMEOUT_MS=2700000              # 45 min (tightened from 2 h: faster staircase decay so losing positions pin at break-even or trip the stop sooner)

# === Diagnostic + calibration bundle (2026-05-19) ===
# All knobs below are observational/calibration only and do not change live
# entry behavior at their defaults. See CLAUDE.md "Diagnostic + calibration
# bundle (2026-05-19)" for the full rationale.

# Drift alerter — surfaces meta.drift on the dashboard. Compares realised
# expectancy over the last N closed trades to the most recent backtest's
# predicted expectancy and flags an alert when they diverge by more than
# DRIFT_ALERT_THRESHOLD_BPS. Observational only — does not gate entries.
DRIFT_ALERT_ENABLED=true
DRIFT_ALERT_MIN_TRADES=10
DRIFT_ALERT_THRESHOLD_BPS=50
DRIFT_ALERT_LOOKBACK_TRADES=100

# Per-symbol expectancy auditor — surfaces meta.perSymbolExpectancy.outliers
# so operators can spot (symbol × signal) cells with negative edge without
# hand-grepping logs. Operators read the list and set MR_SYMBOL_BLOCKLIST_*
# in Render env to act on it; this module never gates entries directly.
PER_SYMBOL_AUDIT_ENABLED=true
PER_SYMBOL_AUDIT_MIN_ENTRIES=5
PER_SYMBOL_AUDIT_OUTLIER_BPS=-20
PER_SYMBOL_AUDIT_LOOKBACK_TRADES=1000

# Phase 2 microstructure calibration — runtime loader for the logistic
# weights fit by scripts/build_microstructure_weights.js. When the file
# exists and is valid, the microstructure signal uses learned weights;
# else falls back to the hand-tuned DEFAULT_WEIGHTS. The runtime never
# fits — fitting is an offline batch via the script.
MICRO_WEIGHTS_FILE=./data/microstructure_weights.json
MICRO_WEIGHTS_LOAD_ENABLED=true

# Auto-calibration scheduler (2026-06-05): closes the learning loop so the
# weight fit runs on a timer instead of waiting for a manual SSH. It runs the
# same buildModel fit and WRITES the weights file when sample count clears the
# floor; new weights go live on the next restart (the signal loads at init and
# does not hot-reload). Below the floor it writes nothing. Master kill = false
# restores the prior manual-only behaviour.
MICRO_AUTO_CALIBRATION_ENABLED=true
MICRO_AUTO_CALIBRATION_INTERVAL_MS=21600000   # 6h

# Shadow labeler (2026-06-05): breaks the data-starvation deadlock that makes
# auto-calibration inert while a non-microstructure signal is the live trader.
# Evaluates the microstructure signal OBSERVATIONALLY across the universe on a
# timer, forward-grades each would-fire candidate at its horizon, and appends
# labeled samples (forward-return proxy, tagged shadow:true) to a SEPARATE file
# the auto-calibration fit also reads. Places NO real trades, bypasses NO veto,
# never touches scanAndEnter. Master kill = false.
MICRO_SHADOW_LABELER_ENABLED=true
MICRO_SHADOW_LABELER_INTERVAL_MS=300000        # 5 min
MICRO_SHADOW_LABELER_HORIZON_MIN=15            # grade forward return at this horizon

# Barrier / microstructure tunables previously hardcoded in the signal
# modules' DEFAULT_CONFIG. Wired through readNumber so the README claim
# "BARRIER_DESIRED_NET_BPS=100 default" is honest. Defaults mirror the
# prior hardcoded values — zero-behavior-change unless an operator flips one.
BARRIER_DESIRED_NET_BPS=100
BARRIER_EV_MIN_BPS=-1
MICRO_STOP_VOL_MULT=2.5
